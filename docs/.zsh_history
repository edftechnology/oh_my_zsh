: 1743305476:0;# coding: utf-8\
""\
CoolProp Thermodynamic Property Calculator with Interactive Graphs\
Includes:\
- Fluid selection\
- Interactive property selection\
- Unit conversion (SI)\
- Engineering notation output\
- Plotly-based diagrams: T-v, p-v, p-T, T-s, h-s, p-h, T-h\
- Outputs saved in timestamped folders with .html and .png\
"""\
\
from CoolProp.CoolProp import PropsSI, get_global_param_string\
import plotly.graph_objects as go\
import pandas as pd\
from datetime import datetime\
import os\
import sys\
\
# === ENGINEERING FORMAT ===\
def eng(x):\
    try:\
        return f"{x:.3e}"\
    except:\
        return x\
\
# === OUTPUT FOLDER ===\
now = datetime.now()\
timestamp = now.strftime("%Y_%m_%d_%H_%M_%S")\
out_dir = os.path.join("outputs", timestamp)\
os.makedirs(out_dir, exist_ok=True)\
\
# === PROPERTY DEFINITIONS ===\
prop_list = [\
    ("T", "Temperature [K]"),\
    ("P", "Pressure [Pa]"),\
    ("D", "Density [kg/m┬│]"),\
    ("V", "Specific Volume [m┬│/kg]"),  # calculated\
    ("UMASS", "Internal Energy [J/kg]"),\
    ("H", "Enthalpy [J/kg]"),\
    ("S", "Entropy [J/kg/K]"),\
    ("CVMASS", "Cv [J/kg/K]"),\
    ("C", "Cp [J/kg/K]"),\
    ("CP/CV", "Cp/Cv"),  # calculated\
    ("CSAT", "Csat [J/kg/K]"),  # placeholder (not directly supported)\
    ("A", "Sound Speed [m/s]"),\
    ("Z", "Compressibility Factor [-]"),\
    ("JT", "Joule-Thomson Coefficient [K/Pa]"),\
    ("Q", "Quality [-]"),\
    ("PHASE", "Phase"),  # placeholder\
    ("G", "Gibbs Energy [J/kg]"),\
    ("F", "Helmholtz Energy [J/kg]"),\
    ("HV", "Heat of Vaporization [J/kg]"),  # placeholder\
    ("B", "2nd Virial Coefficient [m┬│/mol]"),\
    ("C3", "3rd Virial Coefficient [m^6/mol^2]"),\
    ("D4", "4th Virial Coefficient [m^9/mol^3]"),\
]\
\
# === FLUID SELECTION ===\
fluids = sorted(get_global_param_string("FluidsList").split(","))\
fluid_codes = {str(i+1): f for i, f in enumerate(fluids)}\
\
print("Available fluids:")\
for code, name in fluid_codes.items():\
    print(f"{code:>3}: {name}")\
    if int(code) % 10 == 0:\
        print()\
\
raw_fluid = input("Enter fluid code or name (e.g., 107 or Water): ").strip()\
if raw_fluid in fluid_codes:\
    fluid = fluid_codes[raw_fluid]\
elif raw_fluid.lower() in [f.lower() for f in fluids]:\
    fluid = [f for f in fluids if f.lower() == raw_fluid.lower()][0]\
else:\
    print("ŌāĮā¼ Fluid not found.")\
    sys.exit(1)\
print(f"Ōā╝āź Selected fluid: {fluid}")\
\
# === PROPERTY INPUTS ===\
def get_prop_input(n):\
    code = input(f"Enter property {n} (e.g., T, P, H): ").strip().upper()\
    value = float(input(f"Enter value for {code}: "))\
    if code == "T":\
        print("  1: K (Kelvin)\n  2: C (Celsius)")\
        u = input("> ")\
        if u == "2": value += 273.15\
    if code == "P":\
        print("  1: Pa\n  2: kPa\n  3: bar\n  4: MPa")\
        u = input("> ")\
        factor = {"1":1, "2":1e3, "3":1e5, "4":1e6}.get(u, 1)\
        value *= factor\
    return code, value\
\
input1, value1 = get_prop_input(1)\
input2, value2 = get_prop_input(2)\
\
# === PROPERTY SELECTION ===\
print("Select properties to display (e.g. 1,2,5 or all):")\
for i, (_, label) in enumerate(prop_list, 1):\
    print(f"{i:>2}: {label}")\
selected = input("Enter selection: ").strip()\
\
if selected.lower() == "all":\
    selected_props = prop_list\
else:\
    idxs = [int(i)-1 for i in selected.split(",") if i.isdigit()]\
    selected_props = [prop_list[i] for i in idxs if 0 <= i < len(prop_list)]\
\
print("Ōā╝āź Selected properties:")\
for _, label in selected_props:\
    print(" -", label)\
\
# === CALCULATION ===\
results = {}\
for code, label in selected_props:\
    if code == "V":\
        try:\
            d = PropsSI("D", input1, value1, input2, value2, fluid)\
            results[label] = 1/d if d != 0 else "N/A"\
        except: results[label] = "N/A"\
    elif code == "CP/CV":\
        try:\
            cp = PropsSI("C", input1, value1, input2, value2, fluid)\
            cv = PropsSI("CVMASS", input1, value1, input2, value2, fluid)\
            results[label] = cp/cv if cv != 0 else "N/A"\
        except: results[label] = "N/A"\
    elif code == "PHASE":\
        try:\
            q = PropsSI("Q", input1, value1, input2, value2, fluid)\
            results[label] = "Liquid" if q == 0 else "Vapor" if q == 1 else "Mixed" if 0 < q < 1 else "Unknown"\
        except: results[label] = "N/A"\
    elif code == "HV":\
        try:\
            hl = PropsSI("H", "T", value1, "Q", 0, fluid)\
            hv = PropsSI("H", "T", value1, "Q", 1, fluid)\
            results[label] = hv - hl\
        except: results[label] = "N/A"\
    else:\
        try:\
            results[label] = PropsSI(code, input1, value1, input2, value2, fluid)\
        except:\
            results[label] = "N/A"\
\
# === DISPLAY TABLE ===\
df = pd.DataFrame(results.items(), columns=["Property", "Value"])\
df["Value"] = df["Value"].apply(eng)\
print(f"=== Thermodynamic Properties for {fluid} ===")\
print(df.to_string(index=False))\
\
# === PLOTLY DIAGRAMS ===\
import numpy as np\
\
t_vals = np.linspace(PropsSI("TMIN", fluid), PropsSI("TMAX", fluid), 300)\
p_vals = np.logspace(np.log10(PropsSI("PMIN", fluid)+1), np.log10(PropsSI("PMAX", fluid)), 300)\
\
def save_plot(fig, name):\
    html_path = os.path.join(out_dir, f"{name}.html")\
    png_path = os.path.join(out_dir, f"{name}.png")\
    fig.write_html(html_path)\
    fig.write_image(png_path, scale=2)\
    print(f"Saved: {html_path}")\
\
def make_trace(x, y, x_label, y_label, title):\
    fig = go.Figure()\
    fig.add_trace(go.Scatter(x=x, y=y, mode="lines"))\
    fig.update_layout(title=title, xaxis_title=x_label, yaxis_title=y_label)\
    fig.show()\
    return fig\
\
# T-v\
v_vals = [1/PropsSI("D", "T", T, "Q", 0.5, fluid) if PropsSI("D", "T", T, "Q", 0.5, fluid)>0 else None for T in t_vals]\
fig = make_trace(t_vals, v_vals, "Temperature [K]", "Specific Volume [m┬│/kg]", "TŌĆā│v Diagram")\
save_plot(fig, "t_v_diagram")\
\
# p-v\
v_vals = [1/PropsSI("D", "P", P, "Q", 0.5, fluid) if PropsSI("D", "P", P, "Q", 0.5, fluid)>0 else None for P in p_vals]\
fig = make_trace(p_vals, v_vals, "Pressure [Pa]", "Specific Volume [m┬│/kg]", "pŌĆā│v Diagram")\
save_plot(fig, "p_v_diagram")\
\
# p-T\
p_vals_t = [PropsSI("P", "T", T, "Q", 0.5, fluid) for T in t_vals]\
fig = make_trace(t_vals, p_vals_t, "Temperature [K]", "Pressure [Pa]", "pŌĆā│T Diagram")\
save_plot(fig, "p_t_diagram")\
\
# T-s\
s_vals = [PropsSI("S", "T", T, "Q", 0.5, fluid) for T in t_vals]\
fig = make_trace(s_vals, t_vals, "Entropy [J/kg/K]", "Temperature [K]", "TŌĆā│s Diagram")\
save_plot(fig, "t_s_diagram")\
\
# h-s\
h_vals = [PropsSI("H", "T", T, "Q", 0.5, fluid) for T in t_vals]\
fig = make_trace(s_vals, h_vals, "Entropy [J/kg/K]", "Enthalpy [J/kg]", "hŌĆā│s Diagram")\
save_plot(fig, "h_s_diagram")\
\
# p-h\
fig = make_trace(h_vals, p_vals_t, "Enthalpy [J/kg]", "Pressure [Pa]", "pŌĆā│h Diagram")\
save_plot(fig, "p_h_diagram")\
\
# T-h\
fig = make_trace(h_vals, t_vals, "Enthalpy [J/kg]", "Temperature [K]", "TŌĆā│h Diagram")\
save_plot(fig, "t_h_diagram")\
p\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
\
