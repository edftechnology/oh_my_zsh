: 1749584655:0;#!/bin/bash\
\
    # -------- COLOR CONFIGURATION -------- #\
    RED='\033[0;31m'\
    GREEN='\033[0;32m'\
    CYAN='\033[0;36m'\
    NC='\033[0m' # No color\
\
    # -------- OPTIONS -------- #\
    echo -e "${CYAN}Select the code formatter:${NC}"\
    echo "1. autopep8"\
    echo "2. black"\
    read -p "Enter the number of the desired option (1 or 2): " OPTION\
\
    if [[ "$OPTION" == "1" ]]; then\
        FORMATTER="autopep8"\
        echo -e "${GREEN}Running autopep8 recursively...${NC}"\
        find . -type f -name "*.py" | while read -r file; do\
            echo -e "${CYAN}Formatting:${NC} $file"\
            autopep8 "$file" --in-place --aggressive --aggressive\
        done\
    elif [[ "$OPTION" == "2" ]]; then\
        FORMATTER="black"\
        echo -e "${GREEN}Running black on the project...${NC}"\
        black .\
    else\
        echo -e "${RED}Invalid option. Exiting.${NC}"\
        exit 1\
    fi\
\
    echo -e "${GREEN}Code formatting completed successfully using ${FORMATTER}.${NC}"
