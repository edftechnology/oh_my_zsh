: 1755628982:0;OWNER="edftechnology"\
\
add_submodule() {\
  local folder="$1"\
  local repo="$2"\
  local url="git@github.com:$OWNER/$repo.git"\
  echo "[INFO] Adding submodule: $repo into $folder$repo"\
  run git submodule add "$url" "$folder$repo" || {\
    echo "[WARN] Submodule $repo already exists in $folder$repo"\
  }\
}\

