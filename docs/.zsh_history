: 1755024361:0;git push -u origin ita
: 1755024380:0;# veja o que mudou\
git status --porcelain\
\
# guarda tudo (inclui arquivos n├Żo rastreados, se houver)\
git stash push -u -m "pre-rebase"\
\
# atualiza sua branch aplicando seus commits por cima do remoto\
git pull --rebase origin ita\
\
# recupera suas mudan├¦as guardadas\
git stash pop\
\
# se aparecer conflito: edite arquivos, depois\
git add -A\
git rebase --continue   # repita at├® acabar\
\
# por fim\
git push -u origin ita\

