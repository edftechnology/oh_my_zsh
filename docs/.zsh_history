: 1754939062:0;# V├āü para a raiz do repo\
cd "$(git rev-parse --show-toplevel)"\
\
# 1) Garanta as exce├¦├Ąes AP├ā│S a linha ".*/" no .gitignore\
# (edite manualmente, ou use o append abaixo)\
printf '\n!.github/\n!.github/workflows/\n!.github/workflows/**\n' >> .gitignore\
\
# 2) Comite a mudan├¦a do .gitignore (e a remo├¦├Żo do .gitlab-ci.yml, se for o caso)\
git add .gitignore .gitlab-ci.yml 2>/dev/null || true\
git commit -m "Allow tracking .github/workflows in .gitignore" || true\
\
# 3) Verifique se AINDA est├āü sendo ignorado\
git check-ignore -v .github/workflows/latex_build.yml || true\
# Se aparecer alguma linha mostrando que est├āü ignorado, force o add:\
git add -f .github/workflows/latex_build.yml\
\
# 4) Comite e fa├¦a push do workflow\
git commit -m "Add GitHub Actions LaTeX workflow" || true\
git push origin ita_modelagem_reativa_de_materiais_energeticos_velocidade_de_propagacao_da_chama_laminar\

