# fa├¦a stash das mudan├¦as do subm├│dulo\
git submodule foreach --recursive 'git stash -u || true'\
\
# verifique que ficou limpo\
git status\
\
# rode a migra├¦├Żo\
BR=ita_cinetica_quimica_combustao_do_metano_mecanismo_detalhado\
git checkout "$BR"\
git lfs migrate import --include="*.lammpstrj" --include-ref="refs/heads/$BR"\
\
# push reescrevendo a branch\
git push --force-with-lease origin "$BR"\
\
# traga de volta o que estava no stash do(s) subm├│dulo(s)\
git submodule foreach --recursive 'git stash pop || true'\

