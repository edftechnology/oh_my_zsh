: 1755022070:0;# 0) (Opcional) Se tiver mudan├¦as NAO commitadas:\
# git add -A && git commit -m "WIP"   # ou use 'git stash'\
\
git fetch origin\
git switch ita\
\
# Opcional: veja o que o remoto tem a mais\
git log --oneline --graph --decorate HEAD..origin/ita\
\
# Rebase: reaplica seus commits por cima do remoto\
git pull --rebase origin ita\
\
# Se der conflito:\
#   - edite os arquivos conflitantes\
#   - git add <arquivos resolvidos>\
#   - git rebase --continue\
# repita ate terminar\
\
# Quando terminar:\
git push -u origin ita\

